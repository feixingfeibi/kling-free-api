PORT=8010
KLING_API_BASE_URL=https://api-app-cn.klingai.com
KLING_SITE_BASE_URL=https://app.klingai.com
KLING_COOKIE=
KLING_ACCEPT_LANGUAGE=zh-CN,zh;q=0.9
KLING_TIME_ZONE=Asia/Shanghai
# Leave empty to auto-discover a local Chrome/Chromium executable.
# Set this explicitly if auto-discovery fails in your environment.
KLING_BROWSER_EXECUTABLE_PATH=
KLING_BROWSER_USER_DATA_DIR=.browser-profile
KLING_BROWSER_HEADLESS=true
KLING_ENABLE_DEBUG_ROUTES=false
KLING_BROWSER_REQUEST_TIMEOUT_MS=120000
KLING_BROWSER_MODULE_URL=
